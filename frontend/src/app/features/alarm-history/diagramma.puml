@startuml
enum UserRole {
    AMMINISTRATORE
    OPERATORE_SANITARIO
}
interface UserSession {
    +userId: string
    +username: string
    +role: UserRole
    +accessToken: string
    +isFirstAccess: boolean
}
interface LoginResponse {
    +accessToken: string
}
interface RefreshResponse {
    +accessToken: string
}
interface AuthClaims {
    +userId?: string | number
    +sub?: string | number
    +id?: string | number
    +username?: string
    +role?: string
    +isFirstAccess?: boolean
    +firstAccess?: boolean
}
interface TokenResponse {
    +accessToken: string
}
class InternalAuthService {
    -http: unknown
    -baseUrl: string
    -currentUser$: BehaviorSubject<UserSession>
    -token: string
    -restoreSessionInFlight$: Observable<boolean>
    +login(username: string, password: string): Observable<UserSession>
    +setFirstAccessPassword(username: string, temporaryPassword: string, newPassword: string): Observable<UserSession>
    +refreshAccessToken(): Observable<string>
    +restoreSessionFromRefresh(): Observable<boolean>
    +logoutFromBackend(): Observable<void>
    +logout(): void
    +getToken(): string
    +getCurrentUser$(): Observable<UserSession>
    +getRole(): UserRole
    +isAuthenticated(): boolean
    +hasRole(role: UserRole): boolean
    -setSession(session: UserSession): void
    -buildSessionFromAccessToken(accessToken: string): UserSession
    -parseAccessToken(accessToken: string): AuthClaims
    -isUserRole(role: string): boolean
}
enum AlarmPriority {
    WHITE
    GREEN
    ORANGE
    RED
}
interface ActiveAlarm {
    +id: string
    +alarmRuleId: string
    +deviceId?: string
    +alarmName: string
    +priority: AlarmPriority
    +activationTime: string
    +resolutionTime: string
    +position: string
    +userId: number
    +userUsername?: string
}
interface AlarmListVm {
    +alarms: ActiveAlarm[]
    +currentPage: number
    +pageLimit: number
    +pageOffset: number
    +canGoPrevious: boolean
    +canGoNext: boolean
}
interface AlarmRule {
    +id: string
    +name: string
    +thresholdOperator: string
    +thresholdValue: string
    +priority: AlarmPriority
    +armingTime: string | Date
    +dearmingTime: string | Date
    +isArmed: boolean
    +deviceId: string
    +datapointId?: string
    +position: string
}
interface CreateAlarmRuleRequestDto {
    +name: string
    +deviceId: string
    +datapointId?: string
    +plantId: string
    +priority: number
    +thresholdOperator: string
    +thresholdValue: string
    +armingTime: string
    +dearmingTime: string
}
interface UpdateAlarmRuleRequestDto {
    +name: string
    +priority: number
    +thresholdOperator: string
    +thresholdValue: string
    +armingTime: string
    +dearmingTime: string
    +isArmed: boolean
}
class AlarmApiService {
    -http: unknown
    -baseUrl: string
    -alarmsBaseUrl: string
    -alarmEventsBaseUrl: string
    +getAlarmRules(): Observable<AlarmRule[]>
    +getAlarmRule(id: string): Observable<AlarmRule>
    +createAlarmRule(payload: CreateAlarmRuleRequestDto): Observable<AlarmRule>
    +updateAlarmRule(id: string, payload: UpdateAlarmRuleRequestDto): Observable<AlarmRule>
    +deleteAlarmRule(id: string): Observable<void>
    +getActiveAlarms(userId: number, limit?: number, offset?: number): Observable<ActiveAlarm[]>
    +getResolvedAlarms(userId: number, limit?: number, offset?: number): Observable<ActiveAlarm[]>
    +getAlarmEventById(alarmEventId: string): Observable<ActiveAlarm>
    +resolveAlarm(alarmId: string, userId: number): Observable<void>
}
interface ApiErrorDisplayOptions {
    +fallbackMessage: string
    +actionLabel?: string
    +forbiddenMessage?: string
    +nonHttpStrategy?: "fallback" | "message"
}
class ApiErrorDisplayService {
    +toMessage(error: unknown, options: ApiErrorDisplayOptions): string
    -mapHttpError(error: HttpErrorResponse, options: ApiErrorDisplayOptions): string
    -extractHttpMessage(error: HttpErrorResponse): string
    -extractUnknownMessage(error: unknown): string
}
class AlarmHistoryService {
    -alarmApiService: AlarmApiService
    -authService: InternalAuthService
    -apiErrorDisplayService: ApiErrorDisplayService
    -pageLimit: 6
    -pageOffset$: BehaviorSubject<number>
    -canGoNext$: BehaviorSubject<boolean>
    -alarms$: BehaviorSubject<ActiveAlarm[]>
    +vm$: Observable<AlarmListVm>
    +initialize(): void
    +nextPage(): void
    +previousPage(): void
    -loadPage(offset: number): void
}
class AlarmPriorityIndicatorComponent {
    +priority: InputSignal<AlarmPriority>
    +ui: Signal<PriorityUi>
}
class AlarmTableShellComponent {
    +title: InputSignal<string>
    +caption: InputSignal<string>
    +columns: InputSignal<readonly AlarmTableColumn[]>
    +showCreateButton: InputSignal<boolean>
    +createButtonAriaLabel: InputSignal<string>
    +createRequested: OutputEmitterRef<void>
    +onCreateRequest(): void
}
class AlarmHistoryPageComponent implements OnInit {
    -alarmHistoryService: AlarmHistoryService
    +columns: readonly AlarmTableColumn[]
    +ngOnInit(): void
    +vm: any
    +rows: Signal<AlarmTableRow[]>
    +canGoPrevious: Signal<any>
    +canGoNext: Signal<any>
    +currentPage: Signal<any>
    +onNextPage(): void
    +onPreviousPage(): void
    -toRow(alarm: ActiveAlarm): AlarmTableRow
}
@enduml