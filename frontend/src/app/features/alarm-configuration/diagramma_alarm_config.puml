@startuml

interface OnInit

enum AlarmPriority {
    WHITE 
    GREEN
    ORANGE
    RED
}

enum ThresholdOperator {
    GREATER_THAN
    GREATER_THAN_OR_EQUAL
    LESS_THAN
    LESS_THAN_OR_EQUAL
    EQUAL_TO
}

enum AlarmActionButtonTone {
    neutral
    danger
    primary
}

enum DeviceType {
    UNKNOWN
    THERMOSTAT
    FALL_SENSOR
    PRESENCE_SENSOR
    LIGHT
    ALARM_BUTTON
    ENTRANCE_DOOR
    BLIND
}

enum DeviceStatus {
    ONLINE
    OFFLINE
    ALARM
    UNKNOWN
}

interface AlarmRule {
    +id: string
    +name: string
    +thresholdOperator: string
    +thresholdValue: string
    +priority: AlarmPriority
    +armingTime: Date | string
    +dearmingTime: Date | string
    +isArmed: boolean
    +deviceId: string
    +datapointId?: string
    +position: string
}

interface CreateAlarmRuleRequestDto {
    +name: string
    +deviceId: string
    +datapointId?: string
    +plantId: string
    +priority: number
    +thresholdOperator: string
    +thresholdValue: string
    +armingTime: string
    +dearmingTime: string
}

interface UpdateAlarmRuleRequestDto {
    +name: string
    +priority: number
    +thresholdOperator: string
    +thresholdValue: string
    +armingTime: string
    +dearmingTime: string
    +isArmed: boolean
}

interface AlarmConfigFormValue {
    +name: string
    +plantId: string
    +deviceId: string
    +datapointId?: string
    +priority: AlarmPriority | null
    +thresholdOperator: ThresholdOperator | null
    +thresholdValue: string
    +armingTime: string
    +dearmingTime: string
    +enabled: boolean
}

interface AlarmConfigTableRow {
    +id: string
    +name: string
    +position: string
    +priority: AlarmPriority
    +threshold: string
    +armingTime: string
    +dearmingTime: string
    +isEnabled: boolean
}

interface AlarmTableColumn {
    +id: string
    +label: string
}

interface Datapoint {
    +id: string
    +name: string
    +readable: boolean
    +writable: boolean
    +valueType: string
    +enum: string[]
    +sfeType: string
}

interface DeviceAction {
    +key: string
    +label: string
    +disabled?: boolean
}

interface Device {
    +id: string
    +name: string
    +type: DeviceType
    +status: DeviceStatus
    +actions: DeviceAction[]
    +datapoints: Datapoint[]
}

interface Room {
    +id: string
    +name: string
    +hasActiveAlarm: boolean
    +devices: Device[]
}

interface Apartment {
    +id: string
    +name: string
    +isEnabled: boolean
    +rooms: Room[]
}

interface PlantDatapointDto {
    +id: string
    +name: string
    +readable: boolean
    +writable: boolean
    +valueType: string
    +enum?: string[]
    +sfeType: string
}

interface PlantDeviceDto {
    +id: string
    +name: string
    +type?: string
    +subType?: string
    +datapoints?: PlantDatapointDto[]
}

interface PlantRoomDto {
    +id: string
    +name: string
    +devices: PlantDeviceDto[]
}

interface PlantDto {
    +id: string
    +name: string
    +wardId?: number
    +rooms: PlantRoomDto[]
}

interface WardPlantDto {
    +id: string
    +name: string
}

interface WardSummaryDto {
    +id: number
    +name: string
}

interface DeviceDatapointOption {
    +id: string
    +label: string
    +datapoints: Datapoint[]
}

interface AlarmConfigFormLike {
    +controls: { name; plantId; deviceId; datapointId; thresholdOperator }
}

interface DeviceSelectionResult {
    +normalizedDeviceId: string
    +readableDatapoints: Datapoint[]
    +autoSelectedDatapointId: string | null
}

interface DatapointSelectionResult {
    +normalizedDatapointId: string
    +selectedDatapoint: Datapoint | null
}

interface ApplyThresholdConstraintsParams {
    +mode: "create" | "edit"
    +datapoint: Datapoint | null
    +thresholdOperatorControl: AbstractControl
    +thresholdValueControl: AbstractControl
}

interface ApiErrorDisplayOptions {
    +fallbackMessage: string
    +actionLabel?: string
    +forbiddenMessage?: string
    +nonHttpStrategy?: "fallback" | "message"
}

interface PriorityUi {
    +label: string
    +bubbleClass: string
    +symbolClass: string
    +symbol: string
}

class AlarmApiService {
    +getAlarmRules(): Observable<AlarmRule[]>
    +getAlarmRule(id: string): Observable<AlarmRule>
    +createAlarmRule(payload: CreateAlarmRuleRequestDto): Observable<AlarmRule>
    +updateAlarmRule(id: string, payload: UpdateAlarmRuleRequestDto): Observable<AlarmRule>
    +deleteAlarmRule(id: string): Observable<void>
}

class AlarmManagementRefreshService {
    +requestRefresh(): void
    +getRefreshRequested$(): Observable<void>
}

class ApiErrorDisplayService {
    +toMessage(error: unknown, options: ApiErrorDisplayOptions): string
}

class WardApiService {
    +getAvailablePlants(): Observable<WardPlantDto[]>
    +getWards(): Observable<WardSummaryDto[]>
    +getPlantsByWardId(wardId: number): Observable<WardPlantDto[]>
}

class ApartmentApiService {
    +getApartmentByPlantId(plantId: string): Observable<Apartment>
    +getAllPlants(): Observable<PlantDto[]>
}

class AlarmTimeMapper {
    +toFormTime(value: Date | string): string
    -toHourMinute(value: string): string
}

class AlarmRuleFormMapper {
    -alarmTimeMapper: AlarmTimeMapper
    +toFormValue(rule: AlarmRule): AlarmConfigFormValue
    -toFormThresholdOperator(operator: string): ThresholdOperator
}

class AlarmRuleRequestMapper {
    -alarmTimeMapper: AlarmTimeMapper
    -hourMinutePattern: RegExp
    +toCreateRequest(formValue: AlarmConfigFormValue): CreateAlarmRuleRequestDto
    +toUpdateRequest(formValue: AlarmConfigFormValue): UpdateAlarmRuleRequestDto
    +toToggleRequest(rule: AlarmRule, isArmed: boolean): UpdateAlarmRuleRequestDto
}

class DeviceDatapointExtractionService {
    -numericThresholdPattern: RegExp
    +extractDeviceOptions(apartment: Apartment): DeviceDatapointOption[]
    +findReadableDatapoints(deviceId: string, deviceOptions: readonly DeviceDatapointOption[]): Datapoint[]
    +findDatapointById(datapointId: string, datapoints: readonly Datapoint[]): Datapoint | null
    +findDatapointByDeviceAndDatapointId(plants: readonly PlantDto[], deviceId: string, datapointId: string): Datapoint | null
    +getAllowedOperators(datapoint: Datapoint | null): ThresholdOperator[]
    +getEnumValues(datapoint: Datapoint | null): string[]
    +usesEnumeratedThreshold(datapoint: Datapoint | null): boolean
    +normalizeThresholdValue(datapoint: Datapoint | null, value: string): string
    +isThresholdValueValid(datapoint: Datapoint | null, value: string): boolean
}

class AlarmConfigFormValidationHelper {
    -datapointExtraction: DeviceDatapointExtractionService
    +applyThresholdConstraints(params: ApplyThresholdConstraintsParams): void
}

class AlarmConfigFormFieldOrchestratorHelper {
    -datapointExtraction: DeviceDatapointExtractionService
    +applyModeState(form: AlarmConfigFormLike, mode: "create" | "edit"): void
    +resetDatapointControl(form: AlarmConfigFormLike): void
    +resolveDeviceSelection(deviceId: string, deviceOptions: readonly DeviceDatapointOption[]): DeviceSelectionResult
    +resolveDatapointSelection(datapointId: string, datapointOptions: readonly Datapoint[]): DatapointSelectionResult
}

class AlarmConfigFormStateService {
    -hasRequestedPlants: boolean
    -wardApi: WardApiService
    -apartmentApi: ApartmentApiService
    -datapointExtraction: DeviceDatapointExtractionService
    +plants: WritableSignal<WardPlantDto[]>
    +plantsLoadError: WritableSignal<string | null>
    +devicesLoadError: WritableSignal<string | null>
    +isDevicesLoading: WritableSignal<boolean>
    +ensurePlantsLoaded(mode: "create" | "edit"): Observable<void>
    +resetDevicesLoadState(): void
    +loadDeviceOptionsByPlant(plantId: string): Observable<DeviceDatapointOption[]>
    +resolveDatapointForEdit(deviceId: string, datapointId: string): Observable<Datapoint | null>
}

class AlarmConfigStateService {
    -api: AlarmApiService
    -alarmManagementRefreshService: AlarmManagementRefreshService
    -apiErrorDisplayService: ApiErrorDisplayService
    -requestMapper: AlarmRuleRequestMapper
    -alarmsSubject: BehaviorSubject<AlarmRule[]>
    -errorSubject: BehaviorSubject<string | null>
    +alarms$: Observable<AlarmRule[]>
    +error$: Observable<string | null>
    +loadAlarmRules(): void
    +getAlarmRuleById(id: string): Observable<AlarmRule>
    +createAlarmRule(formValue: AlarmConfigFormValue): Observable<AlarmRule>
    +updateAlarmRule(alarmId: string, formValue: AlarmConfigFormValue): Observable<AlarmRule>
    +toggleEnabled(alarmId: string, enabled: boolean): Observable<AlarmRule>
    +deleteAlarmRule(alarmId: string): Observable<void>
}

class AlarmConfigTablePresenterService {
    -alarmTimeMapper: AlarmTimeMapper
    +toRows(rules: AlarmRule[]): AlarmConfigTableRow[]
}

class AlarmPositionLabelUtil <<utility>> {
    +formatAlarmPositionLabel(position: string): string
}

class AlarmConfigFormComponent {
    +mode: InputSignal<"create" | "edit">
    +initialRule: InputSignal<AlarmRule | null>
    +submittedForm: OutputEmitterRef<AlarmConfigFormValue>
    +cancelled: OutputEmitterRef<void>
    -formMapper: AlarmRuleFormMapper
    -formState: AlarmConfigFormStateService
    -datapointExtraction: DeviceDatapointExtractionService
    -validationHelper: AlarmConfigFormValidationHelper
    -fieldOrchestrator: AlarmConfigFormFieldOrchestratorHelper
    +onSubmit(): void
    +onCancel(): void
}

class AlarmConfigPageComponent {
    -stateService: AlarmConfigStateService
    -tablePresenter: AlarmConfigTablePresenterService
    +columns: readonly AlarmTableColumn[]
    +alarms: Signal<AlarmRule[]>
    +error: Signal<string | null>
    +rows: Signal<AlarmConfigTableRow[]>
    +modalTitle: Signal<string>
    +ngOnInit(): void
    +onCreateNew(): void
    +onEdit(alarmRuleId: string): void
    +onToggleEnabled(alarmRuleId: string, enabled: boolean): void
    +onDelete(id: string, name: string): void
    +onDeleteConfirmed(): void
    +onDeleteCancelled(): void
    +onFormSubmitted(formValue: AlarmConfigFormValue): void
    +onModalClosed(): void
}

class AlarmTableShellComponent {
    +columns: InputSignal<readonly AlarmTableColumn[]>
    +createRequested: OutputEmitterRef<void>
}

class AlarmPriorityIndicatorComponent {
    +priority: InputSignal<AlarmPriority>
    +ui: Signal<PriorityUi>
}

class AlarmActionButtonComponent {
    +tone: InputSignal<AlarmActionButtonTone>
    +pressed: OutputEmitterRef<void>
}

class AlarmToggleSwitchComponent {
    +checked: InputSignal<boolean>
    +disabled: InputSignal<boolean>
    +toggled: OutputEmitterRef<boolean>
}

class ConfirmDialogComponent {
    +confirmed: OutputEmitterRef<void>
    +cancelled: OutputEmitterRef<void>
}

class ModalShellComponent {
    +open: InputSignal<boolean>
    +closed: OutputEmitterRef<void>
}

' Realizzazione
AlarmConfigPageComponent ..|> OnInit

' Composizione modelli
Apartment *-- Room
Room *-- Device
Device *-- Datapoint
Device *-- DeviceAction
PlantDto *-- PlantRoomDto
PlantRoomDto *-- PlantDeviceDto
PlantDeviceDto *-- PlantDatapointDto

' Associazioni dominio
AlarmRule --> AlarmPriority
AlarmConfigFormValue --> AlarmPriority
AlarmConfigFormValue --> ThresholdOperator
AlarmConfigTableRow --> AlarmPriority
Device --> DeviceType
Device --> DeviceStatus
DeviceDatapointOption --> Datapoint
DeviceSelectionResult --> Datapoint
DatapointSelectionResult --> Datapoint
ApplyThresholdConstraintsParams --> Datapoint

' Core service deps
AlarmApiService ..> AlarmRule
AlarmApiService ..> CreateAlarmRuleRequestDto
AlarmApiService ..> UpdateAlarmRuleRequestDto
ApiErrorDisplayService ..> ApiErrorDisplayOptions

' Feature services and mappers
AlarmConfigStateService --> AlarmApiService
AlarmConfigStateService --> AlarmManagementRefreshService
AlarmConfigStateService --> ApiErrorDisplayService
AlarmConfigStateService --> AlarmRuleRequestMapper
AlarmConfigStateService ..> AlarmRule
AlarmConfigStateService ..> AlarmConfigFormValue

AlarmConfigFormStateService --> WardApiService
AlarmConfigFormStateService --> ApartmentApiService
AlarmConfigFormStateService --> DeviceDatapointExtractionService
AlarmConfigFormStateService ..> WardPlantDto
AlarmConfigFormStateService ..> Datapoint
AlarmConfigFormStateService ..> DeviceDatapointOption

AlarmConfigTablePresenterService --> AlarmTimeMapper
AlarmConfigTablePresenterService ..> AlarmRule
AlarmConfigTablePresenterService ..> AlarmConfigTableRow
AlarmConfigTablePresenterService ..> AlarmPositionLabelUtil

AlarmRuleFormMapper --> AlarmTimeMapper
AlarmRuleFormMapper ..> AlarmRule
AlarmRuleFormMapper ..> AlarmConfigFormValue
AlarmRuleFormMapper ..> ThresholdOperator

AlarmRuleRequestMapper --> AlarmTimeMapper
AlarmRuleRequestMapper ..> AlarmConfigFormValue
AlarmRuleRequestMapper ..> AlarmRule
AlarmRuleRequestMapper ..> CreateAlarmRuleRequestDto
AlarmRuleRequestMapper ..> UpdateAlarmRuleRequestDto
AlarmRuleRequestMapper ..> AlarmPriority
AlarmRuleRequestMapper ..> ThresholdOperator

DeviceDatapointExtractionService ..> Apartment
DeviceDatapointExtractionService ..> PlantDto
DeviceDatapointExtractionService ..> Datapoint
DeviceDatapointExtractionService ..> ThresholdOperator
DeviceDatapointExtractionService ..> DeviceDatapointOption

AlarmConfigFormValidationHelper --> DeviceDatapointExtractionService
AlarmConfigFormValidationHelper ..> ApplyThresholdConstraintsParams
AlarmConfigFormValidationHelper ..> ThresholdOperator

AlarmConfigFormFieldOrchestratorHelper --> DeviceDatapointExtractionService
AlarmConfigFormFieldOrchestratorHelper ..> AlarmConfigFormLike
AlarmConfigFormFieldOrchestratorHelper ..> DeviceDatapointOption
AlarmConfigFormFieldOrchestratorHelper ..> DeviceSelectionResult
AlarmConfigFormFieldOrchestratorHelper ..> DatapointSelectionResult

WardApiService ..> WardPlantDto
WardApiService ..> WardSummaryDto
ApartmentApiService ..> Apartment
ApartmentApiService ..> PlantDto

' Feature components and shared UI deps
AlarmConfigFormComponent --> AlarmRuleFormMapper
AlarmConfigFormComponent --> AlarmConfigFormStateService
AlarmConfigFormComponent --> DeviceDatapointExtractionService
AlarmConfigFormComponent --> AlarmConfigFormValidationHelper
AlarmConfigFormComponent --> AlarmConfigFormFieldOrchestratorHelper
AlarmConfigFormComponent ..> AlarmRule
AlarmConfigFormComponent ..> AlarmConfigFormValue
AlarmConfigFormComponent ..> AlarmPriority
AlarmConfigFormComponent ..> ThresholdOperator
AlarmConfigFormComponent ..> Datapoint
AlarmConfigFormComponent ..> DeviceDatapointOption
AlarmConfigFormComponent ..> WardPlantDto
AlarmConfigFormComponent ..> AlarmPositionLabelUtil
AlarmConfigFormComponent ..> AlarmPriorityIndicatorComponent
AlarmConfigFormComponent ..> AlarmActionButtonComponent

AlarmConfigPageComponent --> AlarmConfigStateService
AlarmConfigPageComponent --> AlarmConfigTablePresenterService
AlarmConfigPageComponent ..> AlarmRule
AlarmConfigPageComponent ..> AlarmConfigFormValue
AlarmConfigPageComponent ..> AlarmConfigTableRow
AlarmConfigPageComponent ..> AlarmTableColumn
AlarmConfigPageComponent ..> AlarmTableShellComponent
AlarmConfigPageComponent ..> AlarmPriorityIndicatorComponent
AlarmConfigPageComponent ..> AlarmActionButtonComponent
AlarmConfigPageComponent ..> AlarmToggleSwitchComponent
AlarmConfigPageComponent ..> ConfirmDialogComponent
AlarmConfigPageComponent ..> ModalShellComponent
AlarmConfigPageComponent ..> AlarmConfigFormComponent

AlarmTableShellComponent ..> AlarmTableColumn
AlarmPriorityIndicatorComponent ..> AlarmPriority
AlarmPriorityIndicatorComponent ..> PriorityUi
AlarmActionButtonComponent ..> AlarmActionButtonTone

@enduml