@startuml
enum AlarmPriority {
    WHITE
    GREEN
    ORANGE
    RED
}
interface ActiveAlarm {
    +id: string
    +alarmRuleId: string
    +deviceId?: string
    +alarmName: string
    +priority: AlarmPriority
    +activationTime: string
    +resolutionTime: string
    +position: string
    +userId: number
    +userUsername?: string
}
interface AlarmEvent {
    +id: string
    +alarmRuleId: string
    +alarmName: string
    +priority: AlarmPriority
    +activationTime: string
    +resolutionTime: string
}
interface AlarmRule {
    +id: string
    +name: string
    +thresholdOperator: string
    +thresholdValue: string
    +priority: AlarmPriority
    +armingTime: string | Date
    +dearmingTime: string | Date
    +isArmed: boolean
    +deviceId: string
    +datapointId?: string
    +position: string
}
enum AlarmStatus {
    OPEN
    IN_PROGRESS
    RESOLVED
}
enum ConnectionStatus {
    CONNECTED
    DISCONNECTED
    RECONNECTING
}
interface CreateAlarmRuleRequestDto {
    +name: string
    +deviceId: string
    +datapointId?: string
    +plantId: string
    +priority: number
    +thresholdOperator: string
    +thresholdValue: string
    +armingTime: string
    +dearmingTime: string
}
interface UpdateAlarmRuleRequestDto {
    +name: string
    +priority: number
    +thresholdOperator: string
    +thresholdValue: string
    +armingTime: string
    +dearmingTime: string
    +isArmed: boolean
}
enum PushEventType {
    ALARM_TRIGGERED
    ALARM_RESOLVED
    NOTIFICATION
}
interface PushEvent {
    +eventType: PushEventType
    +payload: unknown
    +timestamp: string
}
interface BackendTriggeredPayload {
    +alarmEventId: string
    +wardId: number
    +alarmRuleId: string
}
interface BackendResolvedPayload {
    +alarmEventId: string
    +wardId?: number
}
interface AlarmLifecycleUpdateDetail {
    +type: AlarmLifecycleType
    +alarmEventId: string
}
enum ThresholdOperator {
    GREATER_THAN
    GREATER_THAN_OR_EQUAL
    LESS_THAN
    LESS_THAN_OR_EQUAL
    EQUAL_TO
}
class AlarmApiService {
    -http: unknown
    -baseUrl: string
    -alarmsBaseUrl: string
    -alarmEventsBaseUrl: string
    +getAlarmRules(): Observable<AlarmRule[]>
    +getAlarmRule(id: string): Observable<AlarmRule>
    +createAlarmRule(payload: CreateAlarmRuleRequestDto): Observable<AlarmRule>
    +updateAlarmRule(id: string, payload: UpdateAlarmRuleRequestDto): Observable<AlarmRule>
    +deleteAlarmRule(id: string): Observable<void>
    +getActiveAlarms(userId: number, limit?: number, offset?: number): Observable<ActiveAlarm[]>
    +getResolvedAlarms(userId: number, limit?: number, offset?: number): Observable<ActiveAlarm[]>
