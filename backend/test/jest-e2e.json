{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "../",
  "testMatch": ["<rootDir>/test/e2e/**/*.e2e-spec.ts"],
  "testEnvironment": "node",
  "setupFiles": ["<rootDir>/test/setup-e2e-env.ts"],
  "preset": "ts-jest",
  "moduleNameMapper": {
    "^src/(.*)$": "<rootDir>/src/$1"
  },
  "transform": {
    "^.+\\.(t|j)s$": ["ts-jest", {
      "tsconfig": {
        "types": ["jest", "node"]
      }
    }]
  },
  "transformIgnorePatterns": ["node_modules/(?!(uuid)/)"],
  "collectCoverageFrom": [
    "src/**/application/ports/**/*.ts",
    "src/**/application/repository/**/*.ts"
  ],
  "coveragePathIgnorePatterns": [
    "/node_modules/",
    "\\.module\\.ts$",
    "\\.entity\\.ts$",
    "main\\.ts$"
  ],
  "reporters": [
    "default",
    [
      "jest-html-reporters",
      {
        "pageTitle": "E2E Test Report",
        "publicPath": "<rootDir>/test/e2e/coverage",
        "filename": "jest-e2e-report.html",
        "expand": false,
        "hideIcon": true
      }
    ]
  ]
}

