{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "setupFiles": ["<rootDir>/setup-e2e-env.ts"],
  "testRegex": "e2e/.*\\.e2e-spec.ts$",
  "preset": "ts-jest",
  "moduleNameMapper": {
    "^src/(.*)$": "<rootDir>/../src/$1"
  },
  "transform": {
    "^.+\\.(t|j)s$": ["ts-jest", {
      "tsconfig": {
        "types": ["jest", "node"]
      }
    }]
  },
  "transformIgnorePatterns": ["node_modules/(?!(uuid)/)"],
  "reporters": [
    "default",
    [
      "jest-html-reporters",
      {
        "pageTitle": "E2E Test Report",
        "publicPath": "<rootDir>/../test/e2e/coverage",
        "filename": "jest-e2e-report.html",
        "expand": false,
        "hideIcon": true
      }
    ]
  ]
}

