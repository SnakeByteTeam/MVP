interface AlarmLifecycleNotifierPort {
    +publish(type: AlarmLifecycleType, alarmEventId: string, timestamp: string, details?: AlarmNotificationDetails): void
}
class AlarmLifecycleNotifierService implements AlarmLifecycleNotifierPort {
    -alarmStateService: AlarmStateService
    +publish(type: AlarmLifecycleType, alarmEventId: string, timestamp: string, details?: AlarmNotificationDetails): void
    -publishNotification(type: AlarmLifecycleType, alarmEventId: string, timestamp: string, details?: AlarmNotificationDetails): void
    -publishLifecycleUpdate(type: AlarmLifecycleType, alarmEventId: string): void
}
class AlarmManagementRefreshService {
    -refreshRequested$: Subject<void>
    +requestRefresh(): void
    +getRefreshRequested$(): Observable<void>
}
+createAlarmCollector(alarms: { id: string; alarmRuleId: string; alarmName: string; priority: AlarmPriority; activationTime: string; resolutionTime: string | null; position: string; userId: number | null; }[]): { id: string; alarmRuleId: string; alarmName: string; priority: AlarmPriority; activationTime: string; resolutionTime: string | null; position: string; userId: number | null; }[]
enum UserRole {
    AMMINISTRATORE
    OPERATORE_SANITARIO
}
interface UserSession {
    +userId: string
    +username: string
    +role: UserRole
    +accessToken: string
    +isFirstAccess: boolean
}
interface LoginResponse {
    +accessToken: string
}
interface RefreshResponse {
    +accessToken: string
}
interface AuthClaims {
    +userId?: string | number
    +sub?: string | number
    +id?: string | number
    +username?: string
    +role?: string
    +isFirstAccess?: boolean
    +firstAccess?: boolean
}
interface TokenResponse {
    +accessToken: string
}
class InternalAuthService {
    -http: unknown
    -baseUrl: string
    -currentUser$: BehaviorSubject<UserSession>
    -token: string
    -restoreSessionInFlight$: Observable<boolean>
    +login(username: string, password: string): Observable<UserSession>
    +setFirstAccessPassword(username: string, temporaryPassword: string, newPassword: string): Observable<UserSession>
    +refreshAccessToken(): Observable<string>
    +restoreSessionFromRefresh(): Observable<boolean>
    +logoutFromBackend(): Observable<void>
    +logout(): void
    +getToken(): string
    +getCurrentUser$(): Observable<UserSession>
    +getRole(): UserRole
    +isAuthenticated(): boolean
    +hasRole(role: UserRole): boolean
    -setSession(session: UserSession): void
    -buildSessionFromAccessToken(accessToken: string): UserSession
    -parseAccessToken(accessToken: string): AuthClaims
    -isUserRole(role: string): boolean
}
interface RealtimeAlarmEventNormalizerPort {
    +parseBackendTriggeredPayload(payload: unknown): BackendTriggeredPayload
