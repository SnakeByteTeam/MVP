}

AlarmApiService ..> AlarmRule : "uses"
AlarmApiService ..> CreateAlarmRuleRequestDto : "uses"
AlarmApiService ..> UpdateAlarmRuleRequestDto : "uses"
AlarmApiService ..> ActiveAlarm : "uses"

AlarmApiService o-- HttpClient : "injects"
AlarmApiService o-- API_BASE_URL : "injects"

AlarmLifecycleNotifierService ..|> AlarmLifecycleNotifierPort

AlarmLifecycleNotifierService o-- AlarmStateService : "injects"

AlarmLifecycleNotifierService ..> AlarmNotificationDetails : "uses"
AlarmLifecycleNotifierService ..> AlarmLifecycleType : "uses"
AlarmLifecycleNotifierService ..> AlarmLifecycleUpdateDetail : "uses"

ALARM_LIFECYCLE_NOTIFIER ..> AlarmLifecycleNotifierPort : "provides"
ALARM_LIFECYCLE_NOTIFIER --> AlarmLifecycleNotifierService : "factories"

AlarmStateService ..> ActiveAlarm : "manages"
AlarmStateService ..> NotificationEvent : "manages"
AlarmStateService ..> AlarmEvent : "consumes"
AlarmStateService ..> ActiveAlarmsSnapshotMode : "uses"

AlarmStateService *-- "0..*" ActiveAlarm : "stores"
AlarmStateService *-- "0..*" NotificationEvent : "stores"

EventSubscriptionService o-- SOCKET_IO_FACTORY 
EventSubscriptionService o-- HttpClient 
EventSubscriptionService o-- AlarmApiService 
EventSubscriptionService o-- AlarmStateService 
EventSubscriptionService o-- API_BASE_URL 
EventSubscriptionService o-- InternalAuthService 
EventSubscriptionService o-- RealtimeAlarmEventNormalizerPort 
EventSubscriptionService o-- AlarmLifecycleNotifierPort 
EventSubscriptionService o-- WardSocketRoomCoordinatorPort 

EventSubscriptionService ..> ConnectionStatus 
EventSubscriptionService ..> AlarmPriority  
EventSubscriptionService ..> Socket 

EventSubscriptionService --> AlarmStateService
EventSubscriptionService --> AlarmLifecycleNotifierPort 
EventSubscriptionService --> WardSocketRoomCoordinatorPort 
EventSubscriptionService --> RealtimeAlarmEventNormalizerPort
EventSubscriptionService --> AlarmApiService 

RealtimeAlarmEventNormalizerService ..|> RealtimeAlarmEventNormalizerPort

RealtimeAlarmEventNormalizerService ..> BackendTriggeredPayload : "returns"
RealtimeAlarmEventNormalizerService ..> BackendResolvedPayload : "returns"

REALTIME_ALARM_EVENT_NORMALIZER ..> RealtimeAlarmEventNormalizerPort : "provides"
REALTIME_ALARM_EVENT_NORMALIZER --> RealtimeAlarmEventNormalizerService : "factories"

WardRealtimeCacheService ..> WardIdsByUser 
WardRealtimeCacheService ..> WardIdInput 

WardRealtimeCacheService ..> "sessionStorage" 

WardSocketRoomCoordinatorService ..|> WardSocketRoomCoordinatorPort

WardSocketRoomCoordinatorService o-- WardRealtimeCacheService : "injects (opt)"

WardSocketRoomCoordinatorService ..> UserActivationActions : "returns"

WARD_SOCKET_ROOM_COORDINATOR ..> WardSocketRoomCoordinatorPort : "provides"
WARD_SOCKET_ROOM_COORDINATOR --> WardSocketRoomCoordinatorService : "factories"

NotificationApiService o-- HttpClient : "injects"
NotificationApiService o-- InternalAuthService : "injects"
NotificationApiService o-- API_BASE_URL 

NotificationApiService ..> NotificationEvent : "produces"
NotificationApiService ..> AlarmEventHistoryDto : "consumes"

ApiErrorDisplayService ..> ApiErrorDisplayOptions

ApiErrorDisplayService ..> HttpErrorResponse
ApiErrorDisplayService ..> Error 

BreadcrumbService o-- Router : "injects"
BreadcrumbService o-- ActivatedRoute : "injects"

BreadcrumbService ..> Breadcrumb : "produces"
BreadcrumbService ..> NavigationEnd : "filters"

@enduml