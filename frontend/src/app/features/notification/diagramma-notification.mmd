classDiagram
    class AlarmPriority {
        <<enumeration>>
        WHITE
        GREEN
        ORANGE
        RED
    }

    class NotificationEvent {
        <<abstract>>
        +string notificationId
        +string title
        +string sentAt
        +"triggered"|"resolved"? eventType
    }

    class NotificationListVm {
        <<abstract>>
        +NotificationEvent[] notifications
        +number unreadCount
    }

    class AlarmEventHistoryDto {
        <<abstract>>
        +unknown? id
        +unknown? activationTime
        +unknown? resolutionTime
        +unknown? alarmName
        +unknown? priority
    }

    class UserSession {
        <<abstract>>
        +string userId
    }

    class NotificationPriorityDisplayUtil {
        <<utility>>
        +extractPriorityFromNotificationTitle(title:unknown) AlarmPriority|null
        +stripPriorityFromNotificationTitle(title:unknown) string
    }

    class NotificationTitleUtil {
        <<utility>>
        +formatTriggeredNotificationTitle(alarmName:unknown, priority:unknown, maxLength?:number) string
    }

    class ElapsedTimePipe {
    }

    class AlarmPriorityIndicatorComponent {
    }

    class DatePipe {
    }

    class ActivatedRoute {
    }

    class InternalAuthService {
        +getCurrentUser$() Observable~UserSession|null~
    }

    class AlarmStateService {
        +dismissNotification(notificationId:string) void
        +dismissNotifications(notificationIds:readonly string[]) void
        +removeNotification(notificationId:string) void
        +clearNotifications() void
        +getNotifications$() Observable~NotificationEvent[]~
        +getUnreadNotificationsCount$() Observable~number~
        +getDismissedNotificationIds$() Observable~ReadonlySet~string~~
    }

    class NotificationApiService {
        -HttpClient http
        -string baseUrl
        -InternalAuthService authService
        +getNotificationsHistory() Observable~NotificationEvent[]~
        -fetchManagedAlarmEvents(encodedUserId:string) Observable~AlarmEventHistoryDto[]~
        -fetchUnmanagedAlarmEvents(encodedUserId:string) Observable~AlarmEventHistoryDto[]~
        -mapAlarmEventsToNotifications(alarmEvents:readonly AlarmEventHistoryDto[]) NotificationEvent[]
        -mapAlarmEventToNotification(alarmEvent:AlarmEventHistoryDto) NotificationEvent|null
        -toIsoString(value:unknown) string|null
    }

    class NotificationService {
        -AlarmStateService alarmStateService
        -NotificationApiService notificationApiService
        +removeNotification(notificationId:string) void
        +clearAllNotifications(notifications:readonly NotificationEvent[]) void
        +Observable~NotificationListVm~ vm$
        -toUnixTimestamp(dateValue:string) number
    }

    class NotificationBadgeComponent {
        +InputSignal~number~ count
        +Signal~boolean~ isVisible
        +Signal~string~ displayCount
        +Signal~string~ ariaLabel
    }

    class NotificationItemComponent {
        +InputSignal~NotificationEvent~ notification
        +InputSignal~boolean~ showRemoveAction
        +InputSignal~boolean~ isHighlighted
        +OutputEmitterRef~string~ removeClicked
        +Signal~string~ sentAt
        +Signal~boolean~ isResolved
        +Signal~AlarmPriority|null~ priority
        +Signal~string~ displayTitle
        +Signal~string~ ariaLabel
        +onRemove() void
    }

    class NotificationTopbarPanelComponent {
        +readonly NotificationEvent[] notifications
        +EventEmitter~void~ viewAllClicked
        +EventEmitter~string~ notificationSelected
        +EventEmitter~string~ removeClicked
        +EventEmitter~void~ clearAllClicked
        +readonly NotificationEvent[] visibleNotifications
        +onNotificationSelected(notificationId:string) void
        +onRemove(notificationId:string, event?:Event) void
        +onClearAll() void
        +getPriority(notification:NotificationEvent) AlarmPriority|null
        +getDisplayTitle(notification:NotificationEvent) string
        +getPrioritySymbol(priority:AlarmPriority) string
        +getPriorityBubbleClass(priority:AlarmPriority) string
        +getPrioritySymbolClass(priority:AlarmPriority) string
    }

    class NotificationPageComponent {
        -NotificationService notificationService
        -ActivatedRoute route
        +Observable~NotificationListVm~ vm$
        +Observable~string|null~ highlightedNotificationId$
        +number[] skeletonRows
        +onNotificationRemoved(notificationId:string) void
        +onClearAllNotifications(vm:NotificationListVm) void
        +unreadSummaryLabel(unreadCount:number) string
    }

    class NOTIFICATION_ROUTES {
        <<routes>>
    }

    class authGuard {
        <<guard>>
    }

    %% Relazioni modello
    NotificationListVm *-- NotificationEvent

    %% Relazioni servizi
    NotificationApiService --> InternalAuthService
    NotificationApiService ..> UserSession
    NotificationApiService ..> NotificationEvent
    NotificationApiService ..> AlarmEventHistoryDto
    NotificationApiService ..> NotificationTitleUtil

    NotificationService --> AlarmStateService
    NotificationService --> NotificationApiService
    NotificationService ..> NotificationEvent
    NotificationService ..> NotificationListVm

    %% Relazioni componenti
    NotificationItemComponent ..> NotificationEvent
    NotificationItemComponent ..> AlarmPriority
    NotificationItemComponent ..> ElapsedTimePipe
    NotificationItemComponent ..> AlarmPriorityIndicatorComponent
    NotificationItemComponent ..> NotificationPriorityDisplayUtil

    NotificationTopbarPanelComponent ..> NotificationEvent
    NotificationTopbarPanelComponent ..> AlarmPriority
    NotificationTopbarPanelComponent ..> DatePipe
    NotificationTopbarPanelComponent ..> NotificationPriorityDisplayUtil

    NotificationPageComponent --> NotificationService
    NotificationPageComponent ..> NotificationListVm
    NotificationPageComponent ..> NotificationItemComponent
    NotificationPageComponent ..> ActivatedRoute

    %% Route wiring
    NOTIFICATION_ROUTES ..> NotificationPageComponent : loadComponent()
    NOTIFICATION_ROUTES ..> authGuard : canActivate