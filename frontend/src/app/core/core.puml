    +removeNotification(notificationId: string): void
    +clearNotifications(): void
    +dismissNotification(notificationId: string): void
    +dismissNotifications(notificationIds: readonly string[]): void
    +getActiveAlarms$(): Observable<ActiveAlarm[]>
    +getActiveAlarmsCount$(): Observable<number>
    +getNotifications$(): Observable<NotificationEvent[]>
    +getDismissedNotificationIds$(): Observable<ReadonlySet<string>>
    +getUnreadNotificationsCount$(): Observable<number>
}
+formatTriggeredNotificationTitle(alarmName: unknown, priority: unknown, maxLength?: number): string
+normalizeAlarmName(value: unknown): string
+toPrioritySymbol(value: unknown): string
+normalizePriority(value: unknown): AlarmPriority
+normalizePriorityFromString(compact: string): AlarmPriority
+toEnumPriority(compact: string): AlarmPriority
+isKnownPriority(value: number): boolean
interface AlarmNotificationDetails {
    +alarmName?: string
