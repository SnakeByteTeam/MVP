classDiagram
    class OnInit {
        <<interface>>
    }

    class UserRole {
        <<enumeration>>
        AMMINISTRATORE
        OPERATORE_SANITARIO
    }

    class MyVimarAccount {
        <<interface>>
        +string email
        +boolean isLinked
    }

    class UserSession {
        <<interface>>
        +string userId
        +string username
        +UserRole role
        +string accessToken
        +boolean isFirstAccess
    }

    class LoginResponse {
        <<interface>>
        +string accessToken
    }

    class RefreshResponse {
        <<interface>>
        +string accessToken
    }

    class AuthClaims {
        <<interface>>
        +string|number? userId
        +string|number? sub
        +string|number? id
        +string? username
        +string? role
        +boolean? isFirstAccess
        +boolean? firstAccess
    }

    class TokenResponse {
        <<interface>>
        +string accessToken
    }

    class IVimarCloudApiService {
        <<interface>>
        +getLinkedAccount() Observable~MyVimarAccount~
        +initiateOAuth() void
        +unlinkAccount() Observable~void~
    }

    class ApiErrorDisplayOptions {
        <<interface>>
        +string fallbackMessage
        +string? actionLabel
        +string? forbiddenMessage
        +"fallback"|"message"? nonHttpStrategy
    }

    class PrepareOAuthTicketResponse {
        <<interface>>
        +string ticket
    }

    class MyVimarAccountStatusComponent {
        +InputSignal~MyVimarAccount~ account
        +InputSignal~boolean~ isLoading
        +InputSignal~string~ error
        +OutputEmitterRef~void~ linkClicked
        +OutputEmitterRef~void~ unlinkClicked
        +onLinkAccount() void
        +onUnlinkAccount() void
    }

    class InternalAuthService {
        -unknown http
        -string baseUrl
        -BehaviorSubject~UserSession~ currentUser$
        -string token
        -Observable~boolean~ restoreSessionInFlight$
        +login(username:string, password:string) Observable~UserSession~
        +setFirstAccessPassword(username:string, temporaryPassword:string, newPassword:string) Observable~UserSession~
        +refreshAccessToken() Observable~string~
        +restoreSessionFromRefresh() Observable~boolean~
        +logoutFromBackend() Observable~void~
        +logout() void
        +getToken() string
        +getCurrentUser$() Observable~UserSession~
        +getRole() UserRole
        +isAuthenticated() boolean
        +hasRole(role:UserRole) boolean
        -setSession(session:UserSession) void
        -buildSessionFromAccessToken(accessToken:string) UserSession
        -parseAccessToken(accessToken:string) AuthClaims
        -isUserRole(role:string) boolean
    }

    class ApiErrorDisplayService {
        +toMessage(error:unknown, options:ApiErrorDisplayOptions) string
        -mapHttpError(error:HttpErrorResponse, options:ApiErrorDisplayOptions) string
        -extractHttpMessage(error:HttpErrorResponse) string
        -extractUnknownMessage(error:unknown) string
    }

    class MyVimarCloudApiFeatureService {
        -unknown http
        -string baseUrl
        -ApiErrorDisplayService apiErrorDisplayService
        -string prepareAuthorizeEndpoint
        -string authorizeEndpoint
        -string[] accountEndpoints
        -MyVimarAccount fallbackAccount
        -Document document
        +getLinkedAccount() Observable~MyVimarAccount~
        +initiateOAuth() void
        +unlinkAccount() Observable~void~
        -getLinkedAccountFromEndpoint(index:number) Observable~MyVimarAccount~
        -unlinkAccountFromEndpoint(index:number) Observable~void~
        -isNotFound(error:unknown) boolean
        -showOAuthError(message:string, browser:Window) void
    }

    class MyVimarPageComponent {
        -DestroyRef destroyRef
        -Subject~void~ refresh$
        +Observable~MyVimarAccount~ account$
        +boolean isLoading
        +string error
        -IVimarCloudApiService service
        +ngOnInit() void
        +onLinkAccount() void
        +onUnlinkAccount() void
    }

    %% Realizzazioni e Relazioni
    MyVimarCloudApiFeatureService ..|> IVimarCloudApiService
    MyVimarPageComponent ..|> OnInit
    
    MyVimarAccountStatusComponent ..> MyVimarAccount
    UserSession --> UserRole
    InternalAuthService ..> UserSession
    InternalAuthService ..> UserRole
    InternalAuthService ..> AuthClaims
    MyVimarCloudApiFeatureService --> ApiErrorDisplayService
    MyVimarCloudApiFeatureService ..> MyVimarAccount
    MyVimarPageComponent --> IVimarCloudApiService
    MyVimarPageComponent ..> MyVimarAccount