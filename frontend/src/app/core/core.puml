    -persistJoinedRooms(): void
}
class EventSubscriptionService implements OnDestroy {
    -socketIoFactory: { (opts?: Partial<ManagerOptions & SocketOptions>): Socket<DefaultEventsMap, DefaultEventsMap>; (uri?: string, opts?: Partial<...>): Socket<...>; }
    -http: unknown
    -alarmApiService: AlarmApiService
    -alarmStateService: AlarmStateService
    -apiBaseUrl: string
    -internalAuthService: InternalAuthService
    -eventNormalizer: RealtimeAlarmEventNormalizerPort
    -lifecycleNotifier: AlarmLifecycleNotifierPort
    -roomCoordinator: WardSocketRoomCoordinatorPort
