classDiagram
    class OnInit {
        <<abstract>>
    }
    class OnDestroy {
        <<abstract>>
    }
    class AfterViewInit {
        <<abstract>>
    }

    class UserRole {
        <<enumeration>>
        AMMINISTRATORE
        OPERATORE_SANITARIO
    }

    class NavItem {
        <<abstract>>
        +string label
        +string icon
        +string route
        +UserRole? requiredRole
    }

    class UserInfo {
        <<abstract>>
        +string username
        +string firstName
        +string lastName
        +UserRole role
    }

    class UserSession {
        <<abstract>>
        +string userId
        +string username
        +UserRole role
        +string accessToken
        +boolean isFirstAccess
    }

    class NotificationEvent {
        <<abstract>>
        +string notificationId
        +string title
        +string sentAt
        +"triggered"|"resolved"? eventType
    }

    class MyVimarAccount {
        <<abstract>>
        +string email
        +boolean isLinked
    }

    class Breadcrumb {
        <<abstract>>
        +string label
        +string url
    }

    class BreadcrumbService {
        +Observable~Breadcrumb[]~ breadcrumbs$
    }

    class NavService {
        +getNavItems(role:UserRole) NavItem[]
    }

    class SidebarComponent {
        +NavItem[] navItems
        +boolean isCollapsed
        +boolean isProfileMode
        +boolean canOpenProfile
        +EventEmitter~void~ profileClicked
        +EventEmitter~void~ collapsed
        +EventEmitter~string~ navItemSelected
    }

    class TopbarComponent {
        +UserInfo user
        +boolean isProfileActive
        +boolean isNotificationActive
        +number unreadNotificationsCount
        +boolean showVimarWarning
        +Observable~Breadcrumb[]~ breadcrumbs$
        +EventEmitter~void~ profileClicked
        +EventEmitter~void~ logoutClicked
        +EventEmitter~void~ hamburgerClicked
        +EventEmitter~void~ notificationClicked
        +onNotificationClick() void
        +onProfileClick() void
    }

    class NotificationTopbarPanelComponent {
    }

    class InternalAuthService {
        +getCurrentUser$() Observable~UserSession|null~
        +logoutFromBackend() Observable~void~
    }

    class AlarmStateService {
        +getUnreadNotificationsCount$() Observable~number~
        +getNotifications$() Observable~NotificationEvent[]~
        +getActiveAlarmsCount$() Observable~number~
        +removeNotification(notificationId:string) void
        +clearNotifications() void
    }

    class AlarmManagementRefreshService {
        +requestRefresh() void
    }

    class IVimarCloudApiService {
        <<abstract>>
        +getLinkedAccount() Observable~MyVimarAccount~
    }

    class MyVimarCloudApiFeatureService {
    }

    class VIMAR_CLOUD_API_SERVICE {
        <<injection-token>>
    }

    class Router {
    }

    class MainLayoutComponent {
        +boolean isCollapsed
        +NavItem[] navItems
        +boolean isProfilePanelOpen
        +boolean isAdmin
        +boolean isVimarStatusLoading
        +string vimarStatusError
        +MyVimarAccount|null vimarAccount
        +boolean showVimarAssociationWarning
        +boolean isNotificationPanelOpen
        +string|null realtimeToastMessage
        +"alert"|"success" realtimeToastKind
        +Observable~number~ unreadNotificationsCount$
        +Observable~NotificationEvent[]~ notifications$
        +UserInfo currentUser
        +Observable~number~ activeAlarmCount$
        +ngOnInit() void
        +ngAfterViewInit() void
        +ngOnDestroy() void
        +toggleSidebar() void
        +toggleProfilePanel() void
        +closeProfilePanel() void
        +onNavItemSelected(route:string) void
        +goToVimarLink() void
        +toggleNotificationPanel() void
        +closeNotificationPanel() void
        +openNotificationsArchive() void
        +openNotificationsArchiveFromPreview(notificationId:string) void
        +removeTopbarNotification(notificationId:string) void
        +clearTopbarNotifications() void
        +logout() void
        +canOpenProfilePanel() boolean
    }

    class MAIN_LAYOUT_ROUTES {
        <<routes>>
    }

    %% Realizzazioni
    MainLayoutComponent ..|> OnInit
    MainLayoutComponent ..|> OnDestroy
    MainLayoutComponent ..|> AfterViewInit
    MyVimarCloudApiFeatureService ..|> IVimarCloudApiService

    %% Relazioni modello
    NavItem --> UserRole
    UserInfo --> UserRole
    UserSession --> UserRole
    TopbarComponent ..> UserInfo
    TopbarComponent ..> Breadcrumb
    SidebarComponent ..> NavItem

    %% Relazioni servizi/componenti
    TopbarComponent --> BreadcrumbService
    NavService ..> NavItem
    NavService ..> UserRole

    MainLayoutComponent --> NavService
    MainLayoutComponent --> InternalAuthService
    MainLayoutComponent --> AlarmStateService
    MainLayoutComponent --> AlarmManagementRefreshService
    MainLayoutComponent --> Router
    MainLayoutComponent --> IVimarCloudApiService
    MainLayoutComponent ..> TopbarComponent
    MainLayoutComponent ..> SidebarComponent
    MainLayoutComponent ..> NotificationTopbarPanelComponent
    MainLayoutComponent ..> NavItem
    MainLayoutComponent ..> UserInfo
    MainLayoutComponent ..> UserSession
    MainLayoutComponent ..> NotificationEvent
    MainLayoutComponent ..> MyVimarAccount
    MainLayoutComponent ..> UserRole

    %% Route wiring
    MAIN_LAYOUT_ROUTES ..> MainLayoutComponent : loadComponent()
    MAIN_LAYOUT_ROUTES ..> MyVimarCloudApiFeatureService : providers
    MAIN_LAYOUT_ROUTES ..> VIMAR_CLOUD_API_SERVICE : provide/useExisting
    MAIN_LAYOUT_ROUTES ..> UserRole