@startuml

interface OnInit
interface OnDestroy

enum UserRole {
    AMMINISTRATORE
    OPERATORE_SANITARIO
}

interface User {
    +id: number
    +firstName: string
    +lastName: string
    +username: string
    +role: UserRole
}

interface CreateWardDto {
    +name: string
}

interface UpdateWardDto {
    +name: string
}

interface AssignOperatorDto {
    +userId: number
}

interface AssignPlantDto {
    +plantId: string
}

interface WardUserDto {
    +id: number
    +username: string
}

interface WardPlantDto {
    +id: string
    +name: string
}

interface WardSummaryDto {
    +id: number
    +name: string
}

interface Plant {
    +id: string
    +name: string
}

interface Ward {
    +id: number
    +name: string
    +apartments: Plant[]
    +operators: User[]
}

interface WardManagementState {
    +wards: Ward[]
    +isLoading: boolean
    +error: string | null
}

interface RemoveOperatorEvent {
    +wardId: number
    +userId: number
}

interface RemovePlantEvent {
    +plantId: string
}

class AssignOperatorDialogComponent {
    -formBuilder: FormBuilder
    +wardId: InputSignal<number>
    +availableWards: InputSignal<Ward[]>
    +availableOperators: InputSignal<User[]>
    +submitted: OutputEmitterRef<AssignOperatorDto>
    +cancelled: OutputEmitterRef<void>
    +form: FormGroup
    +ngOnInit(): void
    +onSubmit(): void
    +onCancel(): void
    +getOperatorLabel(operator: User): string
}

class AssignWardDialogComponent {
    -formBuilder: FormBuilder
    +wardId: InputSignal<number>
    +availableWards: InputSignal<Ward[]>
    +availablePlants: InputSignal<Plant[]>
    +submitted: OutputEmitterRef<AssignPlantDto>
    +cancelled: OutputEmitterRef<void>
    +form: FormGroup
    +ngOnInit(): void
    +onSubmit(): void
    +onCancel(): void
}

class WardRowComponent {
    +plant: InputSignal<Plant | null>
}

class WardCardComponent {
    +ward: InputSignal<Ward | null>
    +editWard: OutputEmitterRef<Ward>
    +deleteWard: OutputEmitterRef<number>
    +assignOperator: OutputEmitterRef<number>
    +removeOperator: OutputEmitterRef<RemoveOperatorEvent>
    +assignPlant: OutputEmitterRef<number>
    +removePlant: OutputEmitterRef<RemovePlantEvent>
    -isExpandedSignal: WritableSignal<boolean>
    +isExpanded: Signal<boolean>
    +toggleExpanded(): void
    +onEditWardClick(): void
    +onDeleteWardClick(): void
    +onAssignOperatorClick(): void
    +onRemoveOperatorClick(userId: number): void
    +onAssignPlantClick(): void
    +onRemovePlantClick(plantId: string): void
}

class WardFormDialogComponent {
    -formBuilder: FormBuilder
    +ward: InputSignal<Ward | null>
    +submitted: OutputEmitterRef<CreateWardDto>
    +cancelled: OutputEmitterRef<void>
    +form: FormGroup
    -syncFormWithWard: EffectRef
    +isEditMode: Signal<boolean>
    +onSubmit(): void
    +onCancel(): void
}

class WardApiService {
    -http: HttpClient
    -baseUrl: string
    -wardsEndpoint: string
    -wardUsersRelationshipsEndpoint: string
    -wardPlantsRelationshipsEndpoint: string
    -plantEndpoint: string
    -usersEndpoint: string
    +getWards(): Observable<WardSummaryDto[]>
    +createWard(dto: CreateWardDto): Observable<Ward>
    +updateWard(wardId: number, dto: UpdateWardDto): Observable<Ward>
    +deleteWard(wardId: number): Observable<void>
    +getOperatorsByWardId(wardId: number): Observable<WardUserDto[]>
    +getAvailableOperators(): Observable<WardUserDto[]>
    +assignOperatorToWard(wardId: number, dto: AssignOperatorDto): Observable<void>
    +removeOperatorFromWard(wardId: number, userId: number): Observable<void>
    +getPlantsByWardId(wardId: number): Observable<WardPlantDto[]>
    +getAvailablePlants(): Observable<WardPlantDto[]>
    +assignPlantToWard(wardId: number, dto: AssignPlantDto): Observable<void>
    +removePlantFromWard(plantId: string): Observable<void>
}

class WardHydrationService {
    -api: WardApiService
    +loadHydratedWards(): Observable<Ward[]>
    +hydrateWardSummaries(wardSummaries: WardSummaryDto[]): Observable<Ward[]>
    +mapApartments(apartmentsDto: WardPlantDto[]): Plant[]
    +mapOperators(operatorsDto: WardUserDto[]): User[]
    -toWard(wardSummary: WardSummaryDto): Observable<Ward>
}

class WardStore {
    -state$: BehaviorSubject<WardManagementState>
    +wards$: Observable<Ward[]>
    +isLoading$: Observable<boolean>
    +error$: Observable<string | null>
    -setState(partial: Partial<WardManagementState>): void
    +setWards(wards: Ward[]): void
    +getWardsSnapshot(): Ward[]
    +addWard(ward: Ward): void
    +replaceWard(ward: Ward): void
    +removeWard(wardId: number): void
    +setLoading(value: boolean): void
    +setError(message: string | null): void
}

class EventSubscriptionService {
    +refreshWardRoomSubscription(): void
}

class AssignmentOperationsService {
    -api: WardApiService
    -wardHydration: WardHydrationService
    -store: WardStore
    -eventSubscriptionService: EventSubscriptionService
    +getAvailablePlantsForWard(wardId: number): Observable<Plant[]>
    +getAvailableUsersForWard(wardId: number): Observable<User[]>
    +assignOperator(wardId: number, dto: AssignOperatorDto): Observable<void>
    +removeOperator(wardId: number, userId: number): Observable<void>
    +assignPlant(wardId: number, dto: AssignPlantDto): Observable<void>
    +removePlant(plantId: string): Observable<void>
    -reloadAfter(operation$: Observable<void>): Observable<void>
    -getErrorMessage(error: unknown): string
}

class WardOperationsService {
    -api: WardApiService
    -wardHydration: WardHydrationService
    -store: WardStore
    +loadWards(): Observable<void>
    +createWard(dto: CreateWardDto): Observable<void>
    +updateWard(wardId: number, dto: UpdateWardDto): Observable<void>
    +deleteWard(wardId: number): Observable<void>
    -normalizeMutationWard(ward: Ward): Ward
    -getErrorMessage(error: unknown): string
}

class WardManagementStore {
    -wardStore: WardStore
    -wardOperations: WardOperationsService
    -wardAssignmentOperations: AssignmentOperationsService
    -destroy$: Subject<void>
    +wards$: Observable<Ward[]>
    +isLoading$: Observable<boolean>
    +error$: Observable<string | null>
    +ngOnDestroy(): void
    +loadWards(): void
    +createWard(dto: CreateWardDto): void
    +updateWard(wardId: number, dto: UpdateWardDto): void
    +deleteWard(wardId: number): void
    +assignOperator(wardId: number, dto: AssignOperatorDto): void
    +removeOperator(wardId: number, userId: number): void
    +assignPlant(wardId: number, dto: AssignPlantDto): void
    +removePlant(plantId: string): void
    +getAvailablePlantsForWard(wardId: number): Observable<Plant[] | null>
    +getAvailableUsersForWard(wardId: number): Observable<User[] | null>
    -getErrorMessage(error: unknown): string
}

class ConfirmDialogComponent {
    +message: InputSignal<string>
    +confirmLabel: InputSignal<string>
    +cancelLabel: InputSignal<string>
    +confirmed: OutputEmitterRef<void>
    +cancelled: OutputEmitterRef<void>
    +onConfirm(): void
    +onCancel(): void
}

class WardManagementPageComponent {
    -store: WardManagementStore
    -destroy$: Subject<void>
    +wards$: Observable<Ward[]>
    +isLoading$: Observable<boolean>
    +error$: Observable<string | null>
    +snackbarMessage: WritableSignal<string | null>
    +wardDialogMode: WritableSignal<"closed" | "create" | "edit">
    +selectedWardId: WritableSignal<number | null>
    +selectedApartmentId: WritableSignal<string | null>
    +mobileStep: WritableSignal<"wards" | "apartments" | "operators">
    +operatorWardId: WritableSignal<number | null>
    +availableOperatorsFromFetch: WritableSignal<User[] | null>
    +isLoadingAvailableOperators: WritableSignal<boolean>
    +plantWardId: WritableSignal<number | null>
    +availablePlantsFromFetch: WritableSignal<Plant[] | null>
    +isLoadingAvailablePlants: WritableSignal<boolean>
    +confirmState: WritableSignal<{ kind: "delete-ward"; wardId: number; } | { kind: "remove-operator"; wardId: number; userId: number; } | { kind: "remove-plant"; plantId: string; } | null>
    +wardsSnapshot: WritableSignal<Ward[]>
    +selectedWard: Signal<Ward | null>
    +selectedApartment: Signal<Plant | null>
    +wardDialogValue: Signal<Ward | null>
    +availablePlants: Signal<Plant[]>
    +availableOperators: Signal<User[]>
    +ngOnInit(): void
    +ngOnDestroy(): void
    +dismissSnackbar(): void
    +selectWard(wardId: number): void
    +selectApartment(apartmentId: string): void
    +showWardListStep(): void
    +showApartmentsStep(): void
    +showOperatorsStep(): void
    +onCreateWard(): void
    +onCreateWardSubmit(dto: CreateWardDto): void
    +onEditWard(ward: Ward): void
    +onEditSelectedWard(): void
    +onEditWardSubmit(dto: UpdateWardDto): void
    +onCloseWardDialog(): void
    +onDeleteWard(wardId: number): void
    +onAssignOperator(wardId: number): void
    +onAssignOperatorSubmit(dto: AssignOperatorDto): void
    +onCloseAssignOperatorDialog(): void
    +onRemoveOperator(event: RemoveOperatorEvent): void
    +onAssignPlant(wardId: number): void
    +onAssignPlantSubmit(dto: AssignPlantDto): void
    +onCloseAssignPlantDialog(): void
    +onRemovePlant(event: RemovePlantEvent): void
    +onConfirmDialogConfirmed(): void
    +onConfirmDialogCancelled(): void
    +getConfirmMessage(): string
    +getConfirmLabel(): string
    +getOperatorDisplayName(firstName: string, lastName: string): string
}

class WARD_MANAGEMENT_ROUTES <<routes>>

' Realizzazioni
AssignOperatorDialogComponent ..|> OnInit
AssignWardDialogComponent ..|> OnInit
WardManagementStore ..|> OnDestroy
WardManagementPageComponent ..|> OnInit
WardManagementPageComponent ..|> OnDestroy

' Relazioni dominio
User --> UserRole
Ward *-- Plant
Ward *-- User
WardManagementState --> Ward

' Relazioni componenti
AssignOperatorDialogComponent ..> Ward
AssignOperatorDialogComponent ..> User
AssignOperatorDialogComponent ..> AssignOperatorDto

AssignWardDialogComponent ..> Ward
AssignWardDialogComponent ..> Plant
AssignWardDialogComponent ..> AssignPlantDto

WardRowComponent ..> Plant

WardCardComponent ..> Ward
WardCardComponent ..> RemoveOperatorEvent
WardCardComponent ..> RemovePlantEvent
WardCardComponent ..> WardRowComponent

WardFormDialogComponent ..> Ward
WardFormDialogComponent ..> CreateWardDto

WardManagementPageComponent --> WardManagementStore
WardManagementPageComponent ..> Ward
WardManagementPageComponent ..> User
WardManagementPageComponent ..> Plant
WardManagementPageComponent ..> CreateWardDto
WardManagementPageComponent ..> UpdateWardDto
WardManagementPageComponent ..> AssignOperatorDto
WardManagementPageComponent ..> AssignPlantDto
WardManagementPageComponent ..> RemoveOperatorEvent
WardManagementPageComponent ..> RemovePlantEvent
WardManagementPageComponent ..> WardFormDialogComponent
WardManagementPageComponent ..> AssignOperatorDialogComponent
WardManagementPageComponent ..> AssignWardDialogComponent
WardManagementPageComponent ..> ConfirmDialogComponent

' Relazioni servizi
WardApiService ..> WardSummaryDto
WardApiService ..> WardUserDto
WardApiService ..> WardPlantDto
WardApiService ..> CreateWardDto
WardApiService ..> UpdateWardDto
WardApiService ..> AssignOperatorDto
WardApiService ..> AssignPlantDto
WardApiService ..> Ward

WardHydrationService --> WardApiService
WardHydrationService ..> WardSummaryDto
WardHydrationService ..> WardUserDto
WardHydrationService ..> WardPlantDto
WardHydrationService ..> Ward
WardHydrationService ..> Plant
WardHydrationService ..> User
WardHydrationService ..> UserRole

WardStore --> WardManagementState
WardStore ..> Ward

WardOperationsService --> WardApiService
WardOperationsService --> WardHydrationService
WardOperationsService --> WardStore
WardOperationsService ..> CreateWardDto
WardOperationsService ..> UpdateWardDto
WardOperationsService ..> Ward

AssignmentOperationsService --> WardApiService
AssignmentOperationsService --> WardHydrationService
AssignmentOperationsService --> WardStore
AssignmentOperationsService --> EventSubscriptionService
AssignmentOperationsService ..> AssignOperatorDto
AssignmentOperationsService ..> AssignPlantDto
AssignmentOperationsService ..> Ward
AssignmentOperationsService ..> Plant
AssignmentOperationsService ..> User

WardManagementStore --> WardStore
WardManagementStore --> WardOperationsService
WardManagementStore --> AssignmentOperationsService
WardManagementStore ..> CreateWardDto
WardManagementStore ..> UpdateWardDto
WardManagementStore ..> AssignOperatorDto
WardManagementStore ..> AssignPlantDto
WardManagementStore ..> Plant
WardManagementStore ..> User

' Route wiring
WARD_MANAGEMENT_ROUTES ..> WardStore
WARD_MANAGEMENT_ROUTES ..> WardOperationsService
WARD_MANAGEMENT_ROUTES ..> AssignmentOperationsService
WARD_MANAGEMENT_ROUTES ..> WardManagementStore
WARD_MANAGEMENT_ROUTES ..> WardManagementPageComponent

@enduml