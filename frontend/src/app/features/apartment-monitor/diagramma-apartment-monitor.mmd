classDiagram

    class OnInit {
        <<interface>>
    }

    class OnDestroy {
        <<interface>>
    }

    class AlarmPriority {
        <<enumeration>>
        WHITE
        GREEN
        ORANGE
        RED
    }

    class DeviceType {
        <<enumeration>>
        UNKNOWN
        THERMOSTAT
        FALL_SENSOR
        PRESENCE_SENSOR
        LIGHT
        ALARM_BUTTON
        ENTRANCE_DOOR
        BLIND
    }

    class DeviceStatus {
        <<enumeration>>
        ONLINE
        OFFLINE
        ALARM
        UNKNOWN
    }

    class UserSession {
        <<interface>>
        +string userId
    }

    class ActiveAlarm {
        <<interface>>
        +string id
        +string alarmName
        +AlarmPriority priority
        +string activationTime
        +string|null resolutionTime
        +string position
    }

    class Datapoint {
        <<interface>>
        +string id
        +string name
        +boolean readable
        +boolean writable
        +string valueType
        +string[] enum
        +string sfeType
    }

    class DeviceAction {
        <<interface>>
        +string key
        +string label
        +boolean disabled
    }

    class Device {
        <<interface>>
        +string id
        +string name
        +DeviceType type
        +DeviceStatus status
        +DeviceAction[] actions
        +Datapoint[] datapoints
    }

    class Room {
        <<interface>>
        +string id
        +string name
        +boolean hasActiveAlarm
        +Device[] devices
    }

    class Apartment {
        <<interface>>
        +string id
        +string name
        +boolean isEnabled
        +Room[] rooms
    }

    class ApartmentOption {
        <<interface>>
        +string id
        +string name
    }

    class PlantDatapointDto {
        <<interface>>
        +string id
        +string name
        +boolean readable
        +boolean writable
        +string valueType
        +string[] enum
        +string sfeType
    }

    class PlantDeviceDto {
        <<interface>>
        +string id
        +string name
        +string type
        +string subType
        +PlantDatapointDto[] datapoints
    }

    class PlantRoomDto {
        <<interface>>
        +string id
        +string name
        +PlantDeviceDto[] devices
    }

    class PlantDto {
        <<interface>>
        +string id
        +string name
        +number wardId
        +PlantRoomDto[] rooms
    }

    class AlarmLifecycleUpdateDetail {
        <<interface>>
        +string type
        +string alarmEventId
    }

    class DeviceTypeResolutionInput {
        <<interface>>
        +string rawType
        +string rawSubType
        +string rawName
        +readonly string[] sfeTypes
    }

    class DeviceTaxonomy {
        <<utility>>
        +resolveDeviceType(input DeviceTypeResolutionInput) DeviceType
    }

    class InternalAuthService {
        +getCurrentUser$() Observable~UserSession|null~
    }

    class WardRealtimeCacheService {
        +mergeWardIds(userId string, wardIds readonly string[]) string[]
    }

    class AlarmStateService {
        +getActiveAlarms$() Observable~ActiveAlarm[]~
    }

    class EndpointTableComponent {
    }

    class ApartmentApiService {
        -HttpClient http
        -string baseUrl
        -InternalAuthService authService
        -WardRealtimeCacheService wardRealtimeCache
        -string plantEndpoint
        -string apartmentsEndpoint
        +getCurrentApartment() Observable~Apartment~
        +getAvailableApartments() Observable~ApartmentOption[]~
        +getApartmentByPlantId(plantId string) Observable~Apartment~
        +getAllPlants() Observable~PlantDto[]~
        +enableApartment(apartmentId string) Observable~void~
        +disableApartment(apartmentId string) Observable~void~
        +setActivePlantId(plantId string) void
    }

    class AlarmMapComponent {
        +InputSignal~Room[]~ rooms
        +InputSignal~ActiveAlarm[]~ activeAlarms
        +Signal~number~ alarmedRoomsCount
    }

    class RoomListComponent {
        +InputSignal~Room[]~ rooms
        +OutputEmitterRef~string~ roomSelected
        +onRoomSelect(roomId string) void
    }

    class ApartmentMonitorComponent {
        -ApartmentApiService apartmentApi
        -AlarmStateService alarmState
        -Subject~void~ refresh$
        -Subject~void~ destroy$
        +Observable~ActiveAlarm[]~ activeAlarms$
        +Observable~ApartmentOption[]~ availableApartments$
        +Observable~Apartment|null~ apartment$
        +string error
        +string activeApartmentId
        +ngOnInit() void
        +ngOnDestroy() void
        +onApartmentSelected(apartmentId string) void
    }

    class APARTMENT_MONITOR_ROUTES {
        <<routes>>
    }

    %% Realizzazioni
    ApartmentMonitorComponent ..|> OnInit
    ApartmentMonitorComponent ..|> OnDestroy

    %% Composizione modelli
    Apartment *-- Room
    Room *-- Device
    Device *-- Datapoint
    Device *-- DeviceAction
    PlantDto *-- PlantRoomDto
    PlantRoomDto *-- PlantDeviceDto
    PlantDeviceDto *-- PlantDatapointDto

    %% Relazioni dominio
    Device --> DeviceType
    Device --> DeviceStatus
    ActiveAlarm --> AlarmPriority

    %% Relazioni servizi
    ApartmentApiService --> InternalAuthService
    ApartmentApiService --> WardRealtimeCacheService
    ApartmentApiService ..> UserSession
    ApartmentApiService ..> Apartment
    ApartmentApiService ..> ApartmentOption
    ApartmentApiService ..> PlantDto
    ApartmentApiService ..> PlantDeviceDto
    ApartmentApiService ..> Datapoint
    ApartmentApiService ..> DeviceType
    ApartmentApiService ..> DeviceTaxonomy

    %% Relazioni componenti
    AlarmMapComponent ..> Room
    AlarmMapComponent ..> ActiveAlarm
    RoomListComponent ..> Room
    ApartmentMonitorComponent --> ApartmentApiService
    ApartmentMonitorComponent --> AlarmStateService
    ApartmentMonitorComponent ..> ActiveAlarm
    ApartmentMonitorComponent ..> Apartment
    ApartmentMonitorComponent ..> ApartmentOption
    ApartmentMonitorComponent ..> AlarmLifecycleUpdateDetail
    ApartmentMonitorComponent ..> AlarmMapComponent
    ApartmentMonitorComponent ..> EndpointTableComponent

    %% Route wiring
    APARTMENT_MONITOR_ROUTES ..> ApartmentMonitorComponent