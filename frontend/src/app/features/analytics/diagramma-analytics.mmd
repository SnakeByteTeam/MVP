classDiagram
    class OnInit {
        <<abstract>>
    }

    class ChartDatasetDto {
        <<abstract>>
        +string id
        +string name
        +number[] data
    }

    class EnergySavingSuggestionDto {
        <<abstract>>
        +string[] messages
        +boolean isSuggestion
    }

    class ChartInfoDto {
        <<abstract>>
        +string[] labels
        +ChartDatasetDto[] datasets
        +string title
        +string unit
        +EnergySavingSuggestionDto suggestions
        +string metric
    }

    class AnalyticsDto {
        <<abstract>>
        +string apartmentId
        +ChartInfoDto[] analyticsInfo
    }

    class AnalyticsApiService {
        -HttpClient http
        -string baseUrl
        -string analyticsEndpoint
        -string apartmentsEndpoint
        +getAllApartments() Observable~any[]~
        +getAnalytics(apartmentId:string, refresh?:boolean) Observable~AnalyticsDto~
    }

    class ChartComponent {
        <<abstract>>
        +ChartInfoDto chartInfo
        +ChartType chartType
        +ChartData renderedChartData
        +ChartOptions chartOptions
        +object[] chartColors
        +boolean showSuggestions
        +ngOnChanges(changes:SimpleChanges) void
        #updateChart(data:ChartInfoDto) void
        +showHideSugg() void
    }

    class AlarmFrequencyChartComponent {
        +ChartType chartType
    }

    class AlarmsSentResolvedChartComponent {
        +ChartType chartType
    }

    class EnergyConsumptionChartComponent {
        +ChartType chartType
        +object[] chartColors
        +updateChart(data:ChartInfoDto) void
    }

    class FallFrequencyChartComponent {
        +ChartType chartType
    }

    class PlantAnomaliesChartComponent {
        +ChartType chartType
    }

    class PresenceDetectionChartComponent {
        +ChartType chartType
    }

    class ProlongedPresenceChartComponent {
        +ChartType chartType
    }

    class TemperatureVariationsChartComponent {
        +ChartType chartType
        +object[] chartColors
    }

    class AnalyticsComponent {
        -BehaviorSubject~boolean~ refreshTrigger$
        -AnalyticsApiService analyticsApiService
        -BehaviorSubject~object|null~ loadTrigger$
        +BehaviorSubject~string|null~ selectedApartmentId$
        +Observable~any[]~|null apartments$
        +Observable~AnalyticsDto|null~|null analytics
        +ngOnInit() void
        +getChartByMetric(data:AnalyticsDto|null, metric:string) ChartInfoDto|undefined
        +onApartmentChange(event:Event) void
        +onRefresh() void
    }

    class ANALYTICS_ROUTES {
        <<routes>>
    }

    %% Realizzazione
    AnalyticsComponent ..|> OnInit

    %% Relazioni modello
    ChartInfoDto *-- ChartDatasetDto
    ChartInfoDto --> EnergySavingSuggestionDto
    AnalyticsDto *-- ChartInfoDto

    %% Relazioni API
    AnalyticsApiService ..> AnalyticsDto

    %% Ereditarietà chart
    ChartComponent <|-- AlarmFrequencyChartComponent
    ChartComponent <|-- AlarmsSentResolvedChartComponent
    ChartComponent <|-- EnergyConsumptionChartComponent
    ChartComponent <|-- FallFrequencyChartComponent
    ChartComponent <|-- PlantAnomaliesChartComponent
    ChartComponent <|-- PresenceDetectionChartComponent
    ChartComponent <|-- ProlongedPresenceChartComponent
    ChartComponent <|-- TemperatureVariationsChartComponent
    ChartComponent ..> ChartInfoDto

    %% Relazioni componente principale
    AnalyticsComponent --> AnalyticsApiService
    AnalyticsComponent ..> AnalyticsDto
    AnalyticsComponent ..> ChartInfoDto
    AnalyticsComponent ..> AlarmFrequencyChartComponent
    AnalyticsComponent ..> AlarmsSentResolvedChartComponent
    AnalyticsComponent ..> EnergyConsumptionChartComponent
    AnalyticsComponent ..> FallFrequencyChartComponent
    AnalyticsComponent ..> PlantAnomaliesChartComponent
    AnalyticsComponent ..> PresenceDetectionChartComponent
    AnalyticsComponent ..> ProlongedPresenceChartComponent
    AnalyticsComponent ..> TemperatureVariationsChartComponent

    %% Route wiring
    ANALYTICS_ROUTES ..> AnalyticsComponent