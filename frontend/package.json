{
  "name": "frontend",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --host 0.0.0.0",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:unit": "ng test",
    "test:ci": "ng test --watch=false",
    "test:unit:ci": "ng test --watch=false",
    "test:junit": "ng test --watch=false --reporters=junit --output-file=coverage/frontend/junit.xml",
    "test:sonar": "ng test --watch=false --coverage --coverage-reporters=lcovonly --coverage-reporters=text-summary",
    "test:sonar:junit": "ng test --watch=false --coverage --coverage-reporters=lcovonly --coverage-reporters=text-summary --reporters=junit --output-file=coverage/frontend/junit.xml",
    "test:integration": "ng run frontend:test-integration",
    "test:integration:ci": "ng run frontend:test-integration --watch=false",
    "test:integration:junit": "ng run frontend:test-integration --watch=false --reporters=junit --output-file=coverage/frontend/integration-junit.xml",
    "test:integration:html": "ng run frontend:test-integration --watch=false --reporters=html --output-file=coverage/frontend/integration-html/index.html",
    "test:integration:html:open": "npx vite preview --outDir coverage/frontend/integration-html",
    "test:integration:sonar": "ng run frontend:test-integration --watch=false --coverage --coverage-reporters=lcovonly --coverage-reporters=text-summary && node scripts/filter-integration-lcov.mjs coverage/frontend/lcov.info",
    "e2e": "ng e2e",
    "cypress:open": "cypress open",
    "cypress:run": "cypress run"
  },
  "private": true,
  "packageManager": "npm@11.6.2",
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.4",
    "chart.js": "^4.5.1",
    "ng2-charts": "^10.0.0",
    "rxjs": "~7.8.0",
    "socket.io-client": "^4.8.3",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular-builders/custom-webpack": "^21.0.3",
    "@angular/build": "^21.2.2",
    "@angular/cli": "^21.2.2",
    "@angular/compiler-cli": "^21.2.0",
    "@cypress/code-coverage": "^4.0.3",
    "@cypress/schematic": "^5.0.0",
    "@tailwindcss/postcss": "^4.1.12",
    "@vitest/coverage-v8": "^4.1.2",
    "@vitest/ui": "^4.1.4",
    "babel-plugin-istanbul": "^8.0.0",
    "cypress": "15.13.1",
    "http-server": "^14.1.1",
    "jsdom": "^28.0.0",
    "nyc": "^18.0.0",
    "postcss": "^8.5.3",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.1.12",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
