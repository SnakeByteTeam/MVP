@startuml

interface OnInit
interface OnDestroy

enum DeviceType {
    UNKNOWN
    THERMOSTAT
    FALL_SENSOR
    PRESENCE_SENSOR
    LIGHT
    ALARM_BUTTON
    ENTRANCE_DOOR
    BLIND
}

enum DeviceStatus {
    ONLINE
    OFFLINE
    ALARM
    UNKNOWN
}

interface DeviceAction {
    +key: string
    +label: string
    +disabled?: boolean
}

interface Datapoint {
    +id: string
    +name: string
    +readable: boolean
    +writable: boolean
    +valueType: string
    +enum: string[]
    +sfeType: string
}

interface Device {
    +id: string
    +name: string
    +type: DeviceType
    +status: DeviceStatus
    +actions: DeviceAction[]
    +datapoints: Datapoint[]
}

interface Room {
    +id: string
    +name: string
    +hasActiveAlarm: boolean
    +devices: Device[]
}

interface PlantDatapointDto {
    +id: string
    +name: string
    +readable: boolean
    +writable: boolean
    +valueType: string
    +enum?: string[]
    +sfeType: string
}

interface PlantDeviceDto {
    +id: string
    +name: string
    +type?: string
    +subType?: string
    +datapoints?: PlantDatapointDto[]
}

interface PlantRoomDto {
    +id: string
    +name: string
    +devices: PlantDeviceDto[]
}

interface PlantDto {
    +id: string
    +name: string
    +wardId?: number
    +rooms: PlantRoomDto[]
}

interface DeviceTypeResolutionInput {
    +rawType?: string
    +rawSubType?: string
    +rawName?: string
    +sfeTypes?: readonly string[]
}

class DeviceTaxonomy <<utility>> {
    +resolveDeviceType(input: DeviceTypeResolutionInput): DeviceType
    +getDeviceTypeLabel(type: DeviceType): string
    +getEndpointLabel(sfeType: string): string
}

interface IDeviceCard {
    +roomId: InputSignal<string>
    +device: InputSignal<Device>
}

interface ExecuteActionDto {
    +roomId: string
    +deviceId: string
    +action: string
}

interface WriteDatapointRequest {
    +roomId: string
    +deviceId: string
    +datapointId: string
    +value: string
}

interface WriteDatapointDto {
    +datapointId: string
    +value: string
}

interface DeviceValuePointDto {
    +datapointId: string
    +name: string
    +value: string | number
}

interface DeviceValueDto {
    +deviceId: string
    +values: DeviceValuePointDto[]
}

interface WritableEndpointRow {
    +roomId: string
    +roomName: string
    +deviceId: string
    +deviceName: string
    +deviceType: DeviceType
    +datapointId: string
    +datapointName: string
    +datapointSfeType: string
    +enumValues: string[]
}

interface EndpointRoomGroup {
    +roomId: string
    +roomName: string
    +rows: WritableEndpointRow[]
}

interface RowFeedback {
    +type: "success" | "error"
    +message: string
}

class DeviceApiService {
    -http: HttpClient
    -baseUrl: string
    -plantEndpoint: string
    -deviceEndpoint: string
    +getWritableEndpointRows(): Observable<WritableEndpointRow[]>
    +getRoom(roomId: string): Observable<Room>
    +writeDatapointValue(dto: WriteDatapointDto): Observable<void>
    +getDatapointCurrentValuesByDeviceIds(deviceIds: readonly string[]): Observable<Map<string, string | number>>
    +getCurrentValuePointsByDeviceIds(deviceIds: readonly string[]): Observable<Map<string, DeviceValuePointDto[]>>
    -resolveActivePlantId(): Observable<string>
    -fetchPlantById(plantId: string): Observable<PlantDto>
    -fetchAllPlants(): Observable<PlantDto[]>
    -mapRoomFromPlant(plant: PlantDto, roomId: string): Room
    -mapDatapoints(datapoints: PlantDatapointDto[] | undefined): Datapoint[]
    -mapWritableEndpointRows(plant: PlantDto): WritableEndpointRow[]
}

class DeviceCardComponent {
    +roomId: InputSignal<string>
    +device: InputSignal<Device>
    +isExecuting: InputSignal<boolean>
    +error: InputSignal<string | null>
    +datapointWriteRequested: OutputEmitterRef<WriteDatapointRequest>
    +getTypeLabel(type: DeviceType): string
    +getDatapointLabel(datapoint: Datapoint): string
    +getWritableEnumDatapoints(): Datapoint[]
    +hasWritableDatapoints(): boolean
    +getSelectedValue(datapointId: string, values: string[]): string
    +onSelectionChange(datapointId: string, value: string): void
    +onWriteDatapoint(datapointId: string, values: string[]): void
}

class AlarmButtonCardComponent {
    +roomId: InputSignal<string>
    +device: InputSignal<Device>
    +isExecuting: InputSignal<boolean>
    +error: InputSignal<string | null>
    +actionRequested: OutputEmitterRef<ExecuteActionDto>
    +onAction(action: string): void
}

class BlindCardComponent {
    +roomId: InputSignal<string>
    +device: InputSignal<Device>
    +isExecuting: InputSignal<boolean>
    +error: InputSignal<string | null>
    +actionRequested: OutputEmitterRef<ExecuteActionDto>
    +onAction(action: string): void
}

class EntranceDoorCardComponent {
    +roomId: InputSignal<string>
    +device: InputSignal<Device>
    +isExecuting: InputSignal<boolean>
    +error: InputSignal<string | null>
    +actionRequested: OutputEmitterRef<ExecuteActionDto>
    +onAction(action: string): void
}

class FallSensorCardComponent {
    +roomId: InputSignal<string>
    +device: InputSignal<Device>
    +isExecuting: InputSignal<boolean>
    +error: InputSignal<string | null>
    +actionRequested: OutputEmitterRef<ExecuteActionDto>
    +onAction(action: string): void
}

class LightCardComponent {
    +roomId: InputSignal<string>
    +device: InputSignal<Device>
    +isExecuting: InputSignal<boolean>
    +error: InputSignal<string | null>
    +actionRequested: OutputEmitterRef<ExecuteActionDto>
    +onAction(action: string): void
}

class PresenceSensorCardComponent {
    +roomId: InputSignal<string>
    +device: InputSignal<Device>
    +isExecuting: InputSignal<boolean>
    +error: InputSignal<string | null>
    +actionRequested: OutputEmitterRef<ExecuteActionDto>
    +onAction(action: string): void
}

class ThermostatCardComponent {
    +roomId: InputSignal<string>
    +device: InputSignal<Device>
    +isExecuting: InputSignal<boolean>
    +error: InputSignal<string | null>
    +actionRequested: OutputEmitterRef<ExecuteActionDto>
    +getTypeLabel(type: DeviceType): string
    +onAction(action: string): void
}

class EndpointTableComponent {
    -deviceApi: DeviceApiService
    -refresh$: Subject<void>
    -selectedValuesByRow: Map<string, string>
    -executingRows: Set<string>
    -feedbackByRow: Map<string, RowFeedback>
    -feedbackTimerByRow: Map<string, NodeJS.Timeout>
    -currentValuesByDevice: Map<string, DeviceValuePointDto[]>
    -latestRows: WritableEndpointRow[]
    +roomGroups$: Observable<EndpointRoomGroup[]>
    +loadError: string
    +ngOnInit(): void
    +ngOnDestroy(): void
    +onWriteRow(row: WritableEndpointRow): void
}

class RoomDetailComponent
class DEVICE_INTERACTION_ROUTES <<routes>>
class authGuard <<guard>>

' Realizzazioni
EndpointTableComponent ..|> OnInit
EndpointTableComponent ..|> OnDestroy
DeviceCardComponent ..|> IDeviceCard
AlarmButtonCardComponent ..|> IDeviceCard
BlindCardComponent ..|> IDeviceCard
EntranceDoorCardComponent ..|> IDeviceCard
FallSensorCardComponent ..|> IDeviceCard
LightCardComponent ..|> IDeviceCard
PresenceSensorCardComponent ..|> IDeviceCard
ThermostatCardComponent ..|> IDeviceCard

' Composizione modelli
Device *-- DeviceAction
Device *-- Datapoint
Room *-- Device
PlantDto *-- PlantRoomDto
PlantRoomDto *-- PlantDeviceDto
PlantDeviceDto *-- PlantDatapointDto
EndpointRoomGroup *-- WritableEndpointRow
DeviceValueDto *-- DeviceValuePointDto

' Relazioni dominio
Device --> DeviceType
Device --> DeviceStatus
WritableEndpointRow --> DeviceType

' Relazioni servizi
DeviceApiService ..> Room
DeviceApiService ..> PlantDto
DeviceApiService ..> PlantDeviceDto
DeviceApiService ..> PlantDatapointDto
DeviceApiService ..> Datapoint
DeviceApiService ..> WritableEndpointRow
DeviceApiService ..> WriteDatapointDto
DeviceApiService ..> DeviceValueDto
DeviceApiService ..> DeviceValuePointDto
DeviceApiService ..> DeviceTaxonomy

' Relazioni componenti
DeviceCardComponent ..> Device
DeviceCardComponent ..> Datapoint
DeviceCardComponent ..> DeviceType
DeviceCardComponent ..> WriteDatapointRequest
DeviceCardComponent ..> DeviceTaxonomy

AlarmButtonCardComponent ..> Device
AlarmButtonCardComponent ..> ExecuteActionDto
BlindCardComponent ..> Device
BlindCardComponent ..> ExecuteActionDto
EntranceDoorCardComponent ..> Device
EntranceDoorCardComponent ..> ExecuteActionDto
FallSensorCardComponent ..> Device
FallSensorCardComponent ..> ExecuteActionDto
LightCardComponent ..> Device
LightCardComponent ..> ExecuteActionDto
PresenceSensorCardComponent ..> Device
PresenceSensorCardComponent ..> ExecuteActionDto
ThermostatCardComponent ..> Device
ThermostatCardComponent ..> DeviceType
ThermostatCardComponent ..> ExecuteActionDto
ThermostatCardComponent ..> DeviceTaxonomy

EndpointTableComponent --> DeviceApiService
EndpointTableComponent ..> EndpointRoomGroup
EndpointTableComponent ..> WritableEndpointRow
EndpointTableComponent ..> RowFeedback
EndpointTableComponent ..> DeviceValuePointDto
EndpointTableComponent ..> DeviceType
EndpointTableComponent ..> DeviceTaxonomy

RoomDetailComponent ..> EndpointTableComponent

' Route wiring
DEVICE_INTERACTION_ROUTES ..> RoomDetailComponent : loadComponent()
DEVICE_INTERACTION_ROUTES ..> authGuard : canActivate

@enduml
