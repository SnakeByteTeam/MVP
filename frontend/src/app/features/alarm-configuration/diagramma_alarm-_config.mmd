classDiagram
    class OnInit {
        <<abstract>>
    }

    class AlarmPriority {
        <<enumeration>>
        WHITE
        GREEN
        ORANGE
        RED
    }

    class ThresholdOperator {
        <<enumeration>>
        GREATER_THAN
        GREATER_THAN_OR_EQUAL
        LESS_THAN
        LESS_THAN_OR_EQUAL
        EQUAL_TO
    }

    class AlarmActionButtonTone {
        <<enumeration>>
        neutral
        danger
        primary
    }

    class DeviceType {
        <<enumeration>>
        UNKNOWN
        THERMOSTAT
        FALL_SENSOR
        PRESENCE_SENSOR
        LIGHT
        ALARM_BUTTON
        ENTRANCE_DOOR
        BLIND
    }

    class DeviceStatus {
        <<enumeration>>
        ONLINE
        OFFLINE
        ALARM
        UNKNOWN
    }

    class AlarmRule {
        <<abstract>>
        +string id
        +string name
        +string thresholdOperator
        +string thresholdValue
        +AlarmPriority priority
        +Date|string armingTime
        +Date|string dearmingTime
        +boolean isArmed
        +string deviceId
        +string datapointId
        +string position
    }

    class CreateAlarmRuleRequestDto {
        <<abstract>>
        +string name
        +string deviceId
        +string datapointId
        +string plantId
        +number priority
        +string thresholdOperator
        +string thresholdValue
        +string armingTime
        +string dearmingTime
    }

    class UpdateAlarmRuleRequestDto {
        <<abstract>>
        +string name
        +number priority
        +string thresholdOperator
        +string thresholdValue
        +string armingTime
        +string dearmingTime
        +boolean isArmed
    }

    class AlarmConfigFormValue {
        <<abstract>>
        +string name
        +string plantId
        +string deviceId
        +string datapointId
        +AlarmPriority|null priority
        +ThresholdOperator|null thresholdOperator
        +string thresholdValue
        +string armingTime
        +string dearmingTime
        +boolean enabled
    }

    class AlarmConfigTableRow {
        <<abstract>>
        +string id
        +string name
        +string position
        +AlarmPriority priority
        +string threshold
        +string armingTime
        +string dearmingTime
        +boolean isEnabled
    }

    class AlarmTableColumn {
        <<abstract>>
        +string id
        +string label
    }

    class Datapoint {
        <<abstract>>
        +string id
        +string name
        +boolean readable
        +boolean writable
        +string valueType
        +string[] enum
        +string sfeType
    }

    class DeviceAction {
        <<abstract>>
        +string key
        +string label
        +boolean disabled
    }

    class Device {
        <<abstract>>
        +string id
        +string name
        +DeviceType type
        +DeviceStatus status
        +DeviceAction[] actions
        +Datapoint[] datapoints
    }

    class Room {
        <<abstract>>
        +string id
        +string name
        +boolean hasActiveAlarm
        +Device[] devices
    }

    class Apartment {
        <<abstract>>
        +string id
        +string name
        +boolean isEnabled
        +Room[] rooms
    }

    class PlantDatapointDto {
        <<abstract>>
        +string id
        +string name
        +boolean readable
        +boolean writable
        +string valueType
        +string[] enum
        +string sfeType
    }

    class PlantDeviceDto {
        <<abstract>>
        +string id
        +string name
        +string type
        +string subType
        +PlantDatapointDto[] datapoints
    }

    class PlantRoomDto {
        <<abstract>>
        +string id
        +string name
        +PlantDeviceDto[] devices
    }

    class PlantDto {
        <<abstract>>
        +string id
        +string name
        +number wardId
        +PlantRoomDto[] rooms
    }

    class WardPlantDto {
        <<abstract>>
        +string id
        +string name
    }

    class WardSummaryDto {
        <<abstract>>
        +number id
        +string name
    }

    class DeviceDatapointOption {
        <<abstract>>
        +string id
        +string label
        +Datapoint[] datapoints
    }

    class AlarmConfigFormLike {
        <<abstract>>
        +any controls
    }

    class DeviceSelectionResult {
        <<abstract>>
        +string normalizedDeviceId
        +Datapoint[] readableDatapoints
        +string|null autoSelectedDatapointId
    }

    class DatapointSelectionResult {
        <<abstract>>
        +string normalizedDatapointId
        +Datapoint|null selectedDatapoint
    }

    class ApplyThresholdConstraintsParams {
        <<abstract>>
        +string mode
        +Datapoint|null datapoint
        +AbstractControl thresholdOperatorControl
        +AbstractControl thresholdValueControl
    }

    class ApiErrorDisplayOptions {
        <<abstract>>
        +string fallbackMessage
        +string actionLabel
        +string forbiddenMessage
        +string nonHttpStrategy
    }

    class PriorityUi {
        <<abstract>>
        +string label
        +string bubbleClass
        +string symbolClass
        +string symbol
    }

    class AlarmApiService {
        +getAlarmRules() Observable~AlarmRule[]~
        +getAlarmRule(id:string) Observable~AlarmRule~
        +createAlarmRule(payload:CreateAlarmRuleRequestDto) Observable~AlarmRule~
        +updateAlarmRule(id:string, payload:UpdateAlarmRuleRequestDto) Observable~AlarmRule~
        +deleteAlarmRule(id:string) Observable~void~
    }

    class AlarmManagementRefreshService {
        +requestRefresh() void
        +getRefreshRequested$() Observable~void~
    }

    class ApiErrorDisplayService {
        +toMessage(error:unknown, options:ApiErrorDisplayOptions) string
    }

    class WardApiService {
        +getAvailablePlants() Observable~WardPlantDto[]~
        +getWards() Observable~WardSummaryDto[]~
        +getPlantsByWardId(wardId:number) Observable~WardPlantDto[]~
    }

    class ApartmentApiService {
        +getApartmentByPlantId(plantId:string) Observable~Apartment~
        +getAllPlants() Observable~PlantDto[]~
    }

    class AlarmTimeMapper {
        +toFormTime(value:Date|string) string
        -toHourMinute(value:string) string
    }

    class AlarmRuleFormMapper {
        -AlarmTimeMapper alarmTimeMapper
        +toFormValue(rule:AlarmRule) AlarmConfigFormValue
        -toFormThresholdOperator(operator:string) ThresholdOperator
    }

    class AlarmRuleRequestMapper {
        -AlarmTimeMapper alarmTimeMapper
        -RegExp hourMinutePattern
        +toCreateRequest(formValue:AlarmConfigFormValue) CreateAlarmRuleRequestDto
        +toUpdateRequest(formValue:AlarmConfigFormValue) UpdateAlarmRuleRequestDto
        +toToggleRequest(rule:AlarmRule, isArmed:boolean) UpdateAlarmRuleRequestDto
    }

    class DeviceDatapointExtractionService {
        -RegExp numericThresholdPattern
        +extractDeviceOptions(apartment:Apartment) DeviceDatapointOption[]
        +findReadableDatapoints(deviceId:string, deviceOptions:DeviceDatapointOption[]) Datapoint[]
        +findDatapointById(datapointId:string, datapoints:Datapoint[]) Datapoint|null
        +findDatapointByDeviceAndDatapointId(plants:PlantDto[], deviceId:string, datapointId:string) Datapoint|null
        +getAllowedOperators(datapoint:Datapoint|null) ThresholdOperator[]
        +getEnumValues(datapoint:Datapoint|null) string[]
        +usesEnumeratedThreshold(datapoint:Datapoint|null) boolean
        +normalizeThresholdValue(datapoint:Datapoint|null, value:string) string
        +isThresholdValueValid(datapoint:Datapoint|null, value:string) boolean
    }

    class AlarmConfigFormValidationHelper {
